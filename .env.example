# Supabase Configuration (REQUIRED)
# Get these from: https://app.supabase.com/project/xshjeogimlzltdjpeejp/settings/api
SUPABASE_URL=your-url-here
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WiseOldMan Configuration (OPTIONAL)
WOM_GROUP_ID=2928
WOM_API_KEY=
# Group verification code — required for the sync to ask WOM to refresh
# outdated members from OSRS hiscores. Without it, sync still runs but
# only reads whatever WOM has cached. Found on the WOM group settings page.
WOM_VERIFICATION_CODE=

# Discord Webhooks (OPTIONAL - for notifications)
DISCORD_WEBHOOK_URL=
DISCORD_ANNIVERSARY_WEBHOOK_URL=

# CORS origins for Netlify functions, comma-separated (OPTIONAL).
# Defaults to a built-in allow-list if unset.
ALLOWED_ORIGINS=

# Staging Supabase project (OPTIONAL - used by scripts/staging/* tooling).
STAGING_SUPABASE_URL=
STAGING_SUPABASE_SERVICE_ROLE_KEY=

# Development Mode (OPTIONAL - prevents sending real Discord messages)
NODE_ENV=development

# Sentry Error Tracking (OPTIONAL - for error monitoring)
# Get this from: https://sentry.io/settings/projects/
VITE_SENTRY_DSN=
